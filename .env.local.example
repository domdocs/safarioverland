# Safari Overland — example env. Copy to `.env.local` and fill in.

# ── Public site URL ──────────────────────────────────────────────────────
# Default target for the listing-import CLI; also used by SSR for canonical
# links. Override per-call with `--url <preview>` for preview deployments.
NEXT_PUBLIC_SITE_URL=https://safarioverland.com

# ── Supabase ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only key for API routes; bypasses RLS. Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# ── Admin Basic Auth ─────────────────────────────────────────────────────
# Used by middleware.ts to gate /admin/* and /api/admin/* (including the
# listing-import API). The scripts/import-listing.ts CLI reads the same
# values to authenticate when it POSTs the markdown.
ADMIN_USERNAME=
ADMIN_PASSWORD=

# ── Email (Resend) ───────────────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM_ADDRESS=onboarding@resend.dev
# Where brief-notify emails land (falls back to NOTIFICATION_EMAIL).
PLANNER_INBOX=
NOTIFICATION_EMAIL=

# ── Planner call slot ────────────────────────────────────────────────────
# Calendly (or Cal.com) URL — when set, every "Speak to a planner" button
# embeds the live calendar. Leave empty to render the "calendar isn't live
# yet — email instead" fallback.
NEXT_PUBLIC_CALENDLY_URL=
